# ==============================================================================
# ToggleMesh Configuration Template
# Copy this file to .env and replace the placeholder values before running.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE INFRASTRUCTURE (PostgreSQL & Redis)
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SuperSecretDatabasePassword123!
POSTGRES_DB=togglemesh

TM_DB_HOST=db
TM_DB_PORT=5432
TM_REDIS=redis:6379

# ------------------------------------------------------------------------------
# 1.5. HOST PORTS (Optional overrides to prevent collisions)
# ------------------------------------------------------------------------------
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# API_PORT=5264
# UI_PORT=5173
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_NATIVE_PORT=9000
# KAFKA_PORT=9092


# ------------------------------------------------------------------------------
# 2. SYSTEM SETUP & ADMIN
# ------------------------------------------------------------------------------
TM_RUN_MIGRATIONS_ON_STARTUP=true

# Initial admin account created on first startup
TM_DEFAULT_ADMIN_EMAIL=admin@yourcompany.com
TM_DEFAULT_ADMIN_PASSWORD=AdminPassword123!


# ------------------------------------------------------------------------------
# 3. SECURITY & SECRETS
# ------------------------------------------------------------------------------
# Pepper used for hashing API Keys in the DB (DO NOT CHANGE AFTER DEPLOYMENT)
TM_API_KEY_PEPPER=YourVeryLongAndRandomPepperStringHere_12345!

# Master key for outbound webhooks encryption (Must be Base64 encoded 256-bit / 32-byte key)
# You can generate one via: openssl rand -base64 32
TM_WEBHOOK_MASTER_KEY=dG9nZ2xlbWVzaHNhbXBsZXRvZ2dsZW1lc2hzYW1wbGU=

# Provide a valid RSA Private Key (PEM format, min 2048-bit) for JWT signing.
# If left blank, the system will attempt to auto-generate and persist it.
# TM_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
TM_JWT_ISSUER=ToggleMesh
TM_JWT_AUDIENCE=ToggleMeshClient


# ------------------------------------------------------------------------------
# 4. AUTHENTICATION & RATE LIMITING
# ------------------------------------------------------------------------------
TM_FRONTEND_URL=http://localhost:5173
TM_ALLOW_OPEN_REGISTRATION=false
TM_ALLOW_ORG_CREATION=false
TM_REFRESH_TOKEN_LIFETIME_DAYS=7

# Requests per minute (per IP or API Key)
TM_RATELIMIT_AUTH=10
TM_RATELIMIT_SDK=1000


# ------------------------------------------------------------------------------
# 5. SINGLE SIGN-ON (OIDC) - OPTIONAL
# ------------------------------------------------------------------------------
# TM_OIDC_AUTHORITY=https://accounts.google.com
# TM_OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com
# TM_OIDC_CLIENT_SECRET=your-client-secret


# ------------------------------------------------------------------------------
# 6. SMTP EMAIL DELIVERY - OPTIONAL
# ------------------------------------------------------------------------------
# Set to true to enable email sending, otherwise it defaults to false
# TM_ENABLE_EMAILS=false
# TM_SMTP_HOST=smtp.gmail.com
# TM_SMTP_PORT=587
# TM_SMTP_USERNAME=your-email@gmail.com
# TM_SMTP_PASSWORD=your-app-password
# TM_SMTP_FROM=noreply@togglemesh.com
# TM_SMTP_ENABLE_SSL=true


# ------------------------------------------------------------------------------
# 7. PERFORMANCE & INGESTION
# ------------------------------------------------------------------------------
TM_METRICS_MAX_LIMIT=10000
TM_INGESTION_MAX_BATCH_SIZE=10000
TM_INGESTION_MAX_PAYLOAD_BYTES=5242880


# ------------------------------------------------------------------------------
# 8. ENTERPRISE ANALYTICS (ClickHouse & Kafka) - OPTIONAL
# ------------------------------------------------------------------------------
# Required only if using docker-compose.enterprise.yml
TM_CLICKHOUSE_HOST=clickhouse
TM_CLICKHOUSE_PORT=8123
TM_CLICKHOUSE_DB=default
TM_CLICKHOUSE_USER=default
TM_CLICKHOUSE_PASSWORD=ClickHouseSuperSecret123!
TM_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
TM_ANALYTICS_ROLLUP_INTERVAL=00:15:00