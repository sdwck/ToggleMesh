{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Caching": {
    "DefaultTtlMinutes": 10
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "PrivateKeyPem": "",
    "Issuer": "ToggleMesh",
    "Audience": "ToggleMeshClient"
  },
  "Auth": {
    "RefreshTokenCleanupIntervalHours": 24,
    "FrontendUrl": "http://localhost:5173",
    "RefreshTokenLifetimeDays": 7,
    "AllowOpenRegistration": true,
    "AllowUserOrganizationCreation": true,
    "PasswordPolicy": {
      "MinimumLength": 8,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true
    }
  },
  "OIDC": {
    "Authority": "",
    "ClientId": "",
    "ClientSecret": ""
  },
  "Email": {
    "Smtp": {
      "Host": "",
      "Port": "587",
      "Username": "",
      "Password": "",
      "FromEmail": "noreply@togglemesh.com",
      "EnableSsl": true
    }
  },
  "Metrics": {
    "MaxMetrics": 10000
  },
  "RateLimits": {
    "Auth": 10,
    "Sdk": 1000
  },
  "Analytics": {
    "RollupInterval": "00:15:00"
  },
  "Ingestion": {
    "MaxBatchSize": 10000,
    "MaxPayloadSizeBytes": 5242880
  },
  "Webhooks": {
    "MasterKey": "dG9nZ2xlbWVzaHNhbXBsZXRvZ2dsZW1lc2hzYW1wbGU="
  },
  "DEFAULT_ADMIN_EMAIL": "",
  "DEFAULT_ADMIN_PASSWORD": ""
}